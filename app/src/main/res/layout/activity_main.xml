<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="48dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/greetingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sveiki"
            android:textColor="@color/app_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Dienos kalorijų valdymas"
            android:textColor="@color/app_muted"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/goalText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dienos tikslas: 2000 kcal"
                android:textColor="@color/app_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/consumedText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Suvartota: 0 kcal"
                android:textColor="@color/app_text"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/remainingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Liko: 2000 kcal"
                android:textColor="@color/app_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/addFoodButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/app_primary"
            android:text="Pridėti maistą"
            android:textAllCaps="false"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/summaryButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/app_primary_dark"
            android:text="Dienos suvestinė"
            android:textAllCaps="false"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/goalButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Nustatyti kalorijų tikslą"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Atsijungti"
            android:textAllCaps="false" />
    </LinearLayout>
</ScrollView>
